{% extends 'base.html.twig' %}

{% block title %}Hello BulletinController!{% endblock %}

{% block body %}
<style>
    /* Configuration globale pour l'écran et l'aperçu */
    .page-a4 {
        background: white;
        width: 21cm;
        height: 29.7cm;
        margin: 0.5cm auto;
        padding: 1cm;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.15);
        font-size: 11px; /* Optimisé pour faire tenir les grands tableaux */
        color: #000;
        position: relative;
    }

    /* Style strict pour les tableaux de compétences */
    .table-bulletin {
        width: 100%;
        margin-bottom: 1rem;
        border-collapse: collapse;
    }
    
    .table-bulletin th, 
    .table-bulletin td {
        padding: 0.35rem !important;
        vertical-align: middle !important;
        border: 1px solid #000000 !important;
    }

    .table-bulletin th {
        background-color: #f8f9fa !important;
        font-weight: bold;
    }

    /* Styles spécifiques pour l'impression physique ou PDF */
    @media print {
        body {
            background: none;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .page-a4 {
            width: 21cm;
            height: 29.7cm;
            margin: 0;
            padding: 1cm;
            page-break-after: always;
            box-shadow: none;
        }
        .no-print {
            display: none !important;
        }
    }
</style>

<div class="container-fluid no-print text-center my-3">
    <button class="btn btn-primary px-4" onclick="window.print()">Imprimer le Bulletin (A4)</button>
</div>

