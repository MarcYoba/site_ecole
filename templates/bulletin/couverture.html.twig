{% extends 'base.html.twig' %}

{% block title %}Hello BulletinController!{% endblock %}

{% block body %}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Primary Progress Report Booklet</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Times New Roman', Times, serif;
            color: #000;
        }
        .report-card {
            background-color: #e2f0d9; /* Teinte verdâtre/bleutée du document original */
            border: 2px solid #000;
            padding: 30px;
            max-width: 800px;
            margin: 40px auto;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .header-text {
            font-size: 12px;
            font-weight: bold;
            line-height: 1.2;
        }
        .motto {
            font-style: italic;
            font-size: 11px;
        }
        .logo-container {
            position: relative;
            margin: 20px auto;
            width: 200px;
            height: 200px;
            border: 2px solid #000;
            border-radius: 0 0 100px 100px; /* Forme de blason */
            padding: 15px;
            text-align: center;
            background: #fff;
        }
        .logo-title {
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
        }
        .main-title {
            font-size: 22px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 15px;
        }
        .subtitle {
            font-size: 14px;
            font-weight: bold;
            margin-bottom: 20px;
        }
        .level-badge {
            border: 2px dashed #000;
            padding: 5px 20px;
            font-weight: bold;
            font-size: 16px;
            display: inline-block;
            margin-bottom: 30px;
        }
        .info-label {
            font-weight: bold;
            text-transform: uppercase;
            font-size: 13px;
        }
        .info-line {
            border-bottom: 1px dotted #000;
            height: 25px;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="report-card">
        
        <div class="row text-center header-text mb-4">
            <div class="col-5">
                <div>REPUBLIQUE DU CAMEROUN</div> [cite: 4]
                <div class="motto">Paix - Travail - Patrie</div> [cite: 5]
                <div class="mt-1">MINISTERE DE L'EDUCATION DE BASE</div> [cite: 6]
                <div>INSPECTION GENERALE DES ENSEIGNEMENTS</div> [cite: 7]
            </div>
            
            <div class="col-2 d-flex align-items-center justify-content-center">
                <div style="font-size: 24px;">🇨🇲</div>
            </div>
            
            <div class="col-5">
                <div>REPUBLIC OF CAMEROON</div> [cite: 1]
                <div class="motto">Peace-Work-Fatherland</div> [cite: 1]
                <div class="mt-1">MINISTRY OF BASIC EDUCATION</div> [cite: 2]
                <div>INSPECTORATE GENERAL OF EDUCATION</div> [cite: 3]
            </div>
        </div>

        <hr class="border-dark my-2">

        <div class="text-center my-4">
            <div class="logo-container mx-auto">
                <div class="motto" style="font-size: 9px;">Travail - Excellence</div> [cite: 9]
                <div class="logo-title mt-2" style="font-size: 12px; color: #0d6efd;">
                    Groupe Scolaire Bilingue<br>Les Enfants Bénis
                </div> 
                <div class="mt-3" style="font-size: 24px;">📚✍️</div>
            </div>
        </div>

        <div class="text-center">
            <div class="subtitle text-primary">
                BILINGUAL PRIMARY AND NURSERY SCHOOL "LES ENFANTS BENIS"
            </div> [cite: 11]
            
            <div class="main-title text-danger">
                PRIMARY PROGRESS REPORT BOOKLET
            </div> 
            
            <div class="text-muted small my-2">
                IN CONFORMITY WITH THE 2018 MINEDUB CURRICULUM
            </div> [cite: 13]
            
            <div class="my-3">
                <span class="level-badge text-dark">
                    LEVEL III
                </span> [cite: 14]
            </div>
        </div>

        <div class="row mt-5 px-3">
            <div class="col-12">
                <div class="row align-items-end mb-3">
                    <div class="col-auto info-label">Name of Pupil:</div> [cite: 15]
                    <div class="col info-line">{{ pupil.name|default('') }}</div>
                </div>
            </div>
            
            <div class="col-12">
                <div class="row align-items-end mb-3">
                    <div class="col-auto info-label">Date and Place of Birth:</div> [cite: 16]
                    <div class="col info-line">{{ pupil.birthDateAndPlace|default('') }}</div>
                </div>
            </div>

            <div class="col-12">
                <div class="row align-items-end mb-3">
                    <div class="col-auto info-label">Name of School:</div> [cite: 17]
                    <div class="col info-line">{{ school.name|default('GROUPE SCOLAIRE BILINGUE LES ENFANTS BENIS') }}</div>
                </div>
            </div>

            <div class="col-md-6 col-12">
                <div class="row align-items-end mb-3">
                    <div class="col-auto info-label">Sub-Division:</div> [cite: 18]
                    <div class="col info-line">{{ school.subDivision|default('') }}</div>
                </div>
            </div>

            <div class="col-md-6 col-12">
                <div class="row align-items-end mb-3">
                    <div class="col-auto info-label">Division:</div> [cite: 19]
                    <div class="col info-line">{{ school.division|default('') }}</div>
                </div>
            </div>

            <div class="col-12">
                <div class="row align-items-end mb-3">
                    <div class="col-auto info-label">Region:</div> [cite: 20]
                    <div class="col info-line">{{ school.region|default('') }}</div>
                </div>
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
{% endblock %}