{# form_fiche_renseignements.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}fiche{% endblock %}

{% block body %}
<section class="fiche-container" style="max-width: 800px; margin: auto; font-family: sans-serif; font-size: 12px;">
    
    {# En-tête de l'administration #}
    <div class="header-section" style="display: flex; justify-content: space-between; margin-bottom: 20px;">
        <div>
            <p>Académie de : {{ date | date("Y") }}</p>
            <p><strong>Inspection académique</strong></p>
            <p>_________________________________</p>
        </div>
        <div>
            {# Ici on affiche l'école d'affectation de l'enseignant #}
            <p><strong>École d'affectation :</strong> {{ enseignant.ecole.nom | default('----') }}</p>
        </div>
    </div>

    <h2 style="text-align: center; text-decoration: underline; text-transform: uppercase;">Fiche de Renseignements (Enseignant)</h2>

    <div style="display: flex; gap: 20px; margin-bottom: 10px;">
        <p><strong>Année scolaire :</strong> {{ (date | date("Y")-1) }} / {{ date | date("Y") }}</p>
        <p><strong>Classe tenue :</strong> {{ enseignant.classe.nom | default('----') }}</p>
    </div>

    {# Section IDENTITÉ #}
    <div style="background-color: #ccc; padding: 2px 5px; font-weight: bold;">IDENTITÉ DE L'ENSEIGNANT</div>
    <div class="section-body" style="padding: 10px 0;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
            <span><strong>NOM :</strong> {{ enseignant.nom | upper }}</span>
            <span><strong>MATRICULE :</strong> {{ enseignant.matricule | default('----') }}</span>
            <span>
                <strong>Sexe :</strong> 
                <span style="border: 1px solid #000; padding: 0 5px; min-width: 15px; display: inline-block; text-align: center;">
                    {% if enseignant.genre  %}{% endif %}
                </span> 
                
            </span>
        </div>
        <p style="margin: 5px 0;"><strong>Prénom(s) :</strong> {{ enseignant.prenom }}</p>
        <p style="margin: 5px 0;"><strong>Né(e) le :</strong> {{ enseignant.dateNaissance | date("d/m/Y") }} &nbsp;&nbsp; <strong>Lieu :</strong> {{ enseignant.lieu | default('----') }}</p>
        <p style="margin: 5px 0;"><strong>Grade :</strong> {{ enseignant.grade | default('----') }}</p>
        <p style="margin: 5px 0;"><strong>Téléphone :</strong> {{ enseignant.contact | default('----') }}</p>
    </div>

    {# Section SITUATION PROFESSIONNELLE #}
    <div style="background-color: #ccc; padding: 2px 5px; font-weight: bold;">SITUATION PROFESSIONNELLE</div>
    <div class="section-body" style="padding: 10px 0;">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
            <span><strong>Grade / Corps :</strong> {{ enseignant.grade | default('----') }}</span>
            <span><strong>Fonction :</strong> {{ enseignant.fonction | default('Enseignant') }}</span>
            <span><strong>Date de prise de service :</strong> {{ enseignant.dateEmbauche ? enseignant.dateEmbauche | date("d/m/Y") : '----' }}</span>
            <span><strong>Diplôme le plus élevé :</strong> {{ enseignant.diplome | default('----') }}</span>
        </div>
    </div>

    {# Notes de bas de page #}
    <footer style="margin-top: 30px; font-size: 10px; line-height: 1.2;">
        <p>(1) Cameroun</p>
        <p style="font-style: italic;">* Document administratif confidentiel destiné au suivi du personnel enseignant.</p>
    </footer>

</section>
{% endblock %}