{% extends 'base.html.twig' %}

{% block title %}Dashboard | YOBS{% endblock %}

{% block body %}
    {% include "navbarenseignant.html.twig" %}

    <main class="flex-shrink-0 my-5">
        <div class="container">
            <div class="d-sm-flex align-items-center justify-content-between mb-4">
                <h1 class="h3 mb-0 text-gray-800">Tableau de bord <span class="text text-warning"> Enseignant</span></h1>
            </div>

            <div class="row">
                {# Carte : Classes #}
                {% for matiere in matieres %}
                    <div class="col-xl-3 col-md-6 mb-4">
                        <div class="card border-0 border-start border-success border-4 shadow h-100">
                            <div class="card-body">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                    {{ matiere.nom}}
                                </div>
                                <hr class="my-2 text-gray-200">

                                <div class="d-flex justify-content-between align-items-center pt-2">
                                    <a href="{{ path('app_classe_matire_note',{'id': matiere.id})}}" class="btn btn-sm btn-outline-success border-0">
                                        <i class="fas fa-edit me-1"></i> Note
                                    </a>
                                    <a href="#" class="btn btn-sm btn-outline-primary border-0">
                                        <i class="fas fa-edit me-1"></i> Modifier
                                    </a>
                                    <a href="#" class="btn btn-sm btn-outline-warning border-0">
                                        <i class="fas fa-list"></i> Eleves
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </main>

    {% include "footer.html.twig" %}
{% endblock %}