{% extends 'base.html.twig' %}

{% block title %}Dashboard | YOBS{% endblock %}

{% block body %}
    {% include "navbar.html.twig" %}

    <main class="flex-shrink-0 my-5">
        <div class="container">
            <div class="d-sm-flex align-items-center justify-content-between mb-4">
                <h1 class="h3 mb-0 text-gray-800">Tableau de bord</h1>
            </div>

            <div class="row">
                {# Carte : Classes #}
                <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-0 border-start border-success border-4 shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                        Classes
                                    </div>
                                    <div class="h6 mb-2 font-weight-bold text-gray-800">
                                        Total : {{ classCount|default(0) }}
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <a href="{{ path('app_classe') }}" class="btn btn-sm btn-primary">
                                    <i class="fas fa-plus-circle"></i> Ajouter
                                </a>
                                <a href="{{ path('app_classe_liste') }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-list"></i> Liste
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                {# Carte : Élèves #}
                <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-0 border-start border-danger border-4 shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                                        Élèves
                                    </div>
                                    <div class="h6 mb-2 font-weight-bold text-gray-800">
                                        Total : {{ eleveCount | default(0) }}
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <a href="{{ path('app_eleve') }}" class="btn btn-sm btn-primary">
                                    <i class="fas fa-user-plus"></i> Ajouter
                                </a>
                                <a href="{{ path('app_eleve_liste') }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-list"></i> Liste
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                {# Carte : Enseignants #}
                <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-0 border-start border-info border-4 shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                        Enseignants
                                    </div>
                                    <div class="h6 mb-2 font-weight-bold text-gray-800">
                                        Total : {{ enseignantCount | default(0) }}
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <a href="{{ path('app_enseignant')}}" class="btn btn-sm btn-primary">
                                    <i class="fas fa-chalkboard-user"></i> Ajouter
                                </a>
                                <a href="{{ path('app_enseignant_liste') }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-list"></i> Liste
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                {# Carte : Manuels scolaires #}
                <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-0 border-start border-warning border-4 shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                        Manuels scolaires
                                    </div>
                                    <div class="h6 mb-2 font-weight-bold text-gray-800">
                                        Total : {{ bookCount|default(0) }}
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <a href="#" class="btn btn-sm btn-primary">
                                    <i class="fas fa-upload"></i> Ajouter
                                </a>
                                <a href="#" class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-download"></i> Télécharger liste
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-0 border-start border-warning border-4 shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                        Inscription eleve
                                    </div>
                                    <div class="h6 mb-2 font-weight-bold text-gray-800">
                                        Total : {{ bookCount|default(0) }}
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <a href="{{ path('app_inscription') }} " class="btn btn-sm btn-primary">
                                    <i class="fas fa-plus"></i> Ajouter
                                </a>
                                <a href="{{ path('app_inscription_list') }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-list"></i> liste
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-0 border-start border-warning border-4 shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                        Enregistrement des matieres
                                    </div>
                                    <div class="h6 mb-2 font-weight-bold text-gray-800">
                                        Total : {{ matiereCount |default(0) }}
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <a href="{{ path('app_matiere') }} " class="btn btn-sm btn-primary">
                                    <i class="fas fa-plus"></i> Ajouter
                                </a>
                                <a href="{{ path('app_matiere_list') }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-list"></i> liste
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-3 col-md-6 mb-4">
                    <div class="card border-0 border-start border-warning border-4 shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                        Enregistrement des Notes
                                    </div>
                                    <div class="h6 mb-2 font-weight-bold text-gray-800">
                                        Total : {{ noteCount |default(0) }}
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <a href="{{ path('app_note') }} " class="btn btn-sm btn-primary">
                                    <i class="fas fa-plus"></i> Ajouter
                                </a>
                                <a href="{{ path('app_note_list') }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-list"></i> liste
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                {# Carte : Statistiques générales #}
                <div class="col-xl-4 col-md-6 mb-4">
                    <div class="card border-0 border-start border-secondary border-4 shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">
                                        Statistiques générales
                                    </div>
                                    <div class="h6 mb-2 font-weight-bold text-gray-800">
                                        École YOBS
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between mt-3">
                                <a href="#" class="btn btn-sm btn-primary">
                                    <i class="fas fa-chart-line"></i> Consultation
                                </a>
                                <a href="#" class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-file-pdf"></i> Téléchargement
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    {% include "footer.html.twig" %}
{% endblock %}