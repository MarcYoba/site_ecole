{% extends "base.html.twig" %}

{% block title %}Hello RapportController {% endblock %}

{% block body %}
{% include "navbar.html.twig" %}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Rapports</title>

</head>

<body id="page-top">

    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="text-center mt-5 mb-4">
                    <h1 class="h4 text-gray-900">Génération de Rapports d'incriptions </h1>
                    
                </div>
            </div>
        </div>

        <div class="row">

            <div class="col-xl-6 col-md-6 mb-4">
                <div class="card border-left-success shadow h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                    Rapport des inscription par jour
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">Rapport du Jour</div>
                            </div>
                            <div class="col-auto">
                                <a href="{{ path('app_inscription_jour')}}">
                                    <button type="button" class="btn btn-success btn-sm">
                                        <i class="fas fa-print fa-2x text-white-50"></i> Générer
                                    </button>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-6 col-md-6 mb-4">
                <div class="card border-left-primary shadow h-100 py-2">
                    <div class="card-body">
                        <form class="user" action="{{ path('app_inscription_date_jour')}}" method="post">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                        Rapport Ponctuel
                                    </div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">Rapport pour une Date Précise</div>
                                    <div class="form-group mt-2">
                                        <input type="date" class="form-control form-control-sm" id="date"
                                            name="date" required>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="fas fa-calendar-alt fa-2x text-white-50"></i> Générer
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-xl-6 col-md-6 mb-4">
                <div class="card border-left-primary shadow h-100 py-2">
                    <div class="card-body">
                        <form class="user" action="{{ path('app_inscription_semaine')}}" method="post">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                        Rapport Incription semaine
                                    </div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">Rapport pour une Date Précise</div>
                                    <div class="form-group mt-2">
                                        <input type="date" class="form-control form-control-sm" id="date1"
                                            name="date1" required>
                                    </div>
                                    <div class="form-group mt-2">
                                        <input type="date" class="form-control form-control-sm" id="date2"
                                            name="date2" required>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="fas fa-calendar-alt fa-2x text-white-50"></i> Générer
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>
        </div>

</body>
</html>
{% include "footer.html.twig" %}
{% endblock %}