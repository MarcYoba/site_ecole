{% extends 'base.html.twig' %}

{% block title %}Eleve!{% endblock %}

{% block body %}
<section class="h-100 bg-dark">
  <div class="container py-5 h-100">
    <div class="row d-flex justify-content-center align-items-center h-100">
      <div class="col">
        <div class="card card-registration my-4">
        {{ form_start(form) }}
          <div class="row g-0">
            <div class="col-xl-6 d-none d-xl-block">
                <div class="form-group row">
                    <div class="col-md-3">
                        <a class="btn btn-primary" href="{{ path('app_home_dashboard') }}"> Retour</a>
                    </div>
                </div>
                <h3 class="mb-5 text-uppercase">Student registration </h3>
                <div class="row">
                  <div class="col-md-6 mb-4">
                    <div data-mdb-input-init class="form-outline">
                      {{ form_label(form.nom) }}
                      {{ form_widget(form.nom) }}
                    </div>
                  </div>
                  <div class="col-md-6 mb-4">
                    <div data-mdb-input-init class="form-outline">
                      {{ form_label(form.prenom) }}
                      {{ form_widget(form.prenom) }}
                    </div>
                  </div>
                </div>
                <div class="row">
                  <div class="col-md-4 mb-4">
                    <div data-mdb-input-init class="form-outline">
                      {{ form_label(form.matricule) }}
                      {{ form_widget(form.matricule) }}
                    </div>
                  </div>
                  <div class="col-md-5 mb-4">
                    <div data-mdb-input-init class="form-outline">
                      {{ form_label(form.naissance) }}
                      {{ form_widget(form.naissance) }}
                    </div>
                  </div>
                  <div class="col-md-3 mb-4">
                    <div data-mdb-input-init class="form-outline">
                      {{ form_label(form.age) }}
                      {{ form_widget(form.age) }}
                    </div>
                  </div>
                </div>
                <div class="row">
                  <div class="col-md-6 mb-4">
                    <div data-mdb-input-init class="form-outline">
                      {{ form_label(form.lieu) }}
                      {{ form_widget(form.lieu) }}
                    </div>
                  </div>
                  <div class="col-md-6 mb-4">
                    <div data-mdb-input-init class="form-outline">
                      {{ form_label(form.ville) }}
                      {{ form_widget(form.ville) }}
                    </div>
                  </div>
                </div>
                <div class="row">
                  <div class="col-md-6 mb-4">
                    {{ form_label(form.classe) }}
                    {{ form_widget(form.classe) }}
                  </div>
                  <div class="col-md-6 mb-4">
                    {{ form_label(form.sexe) }}
                    {{ form_widget(form.sexe) }}
                  </div>
                </div>
            </div>
            <div class="col-xl-6">
              <div class="card-body p-md-5 text-black">
              <div data-mdb-input-init class="form-outline mb-4">
                  {{ form_label(form.mere) }}
                  {{ form_widget(form.mere) }}
              </div>
              <div class="row">
                  <div class="col-md-4 mb-4">
                    {{ form_label(form.autoriseMere) }}
                    {{ form_widget(form.autoriseMere) }}
                  </div>
                  <div class="col-md-4 mb-4">
                    {{ form_label(form.professionMere) }}
                    {{ form_widget(form.professionMere) }}
                  </div>
                  <div class="col-md-4 mb-4">
                    {{ form_label(form.telephoneMere) }}
                    {{ form_widget(form.telephoneMere) }}
                  </div>
              </div>
              <div data-mdb-input-init class="form-outline mb-4">
                  {{ form_label(form.pere) }}
                  {{ form_widget(form.pere) }}
              </div>
              <div class="row">
                  <div class="col-md-4 mb-4">
                    {{ form_label(form.autorisePere) }}
                    {{ form_widget(form.autorisePere) }}
                  </div>
                  <div class="col-md-4 mb-4">
                    {{ form_label(form.professionPere) }}
                    {{ form_widget(form.professionPere) }}
                  </div>
                  <div class="col-md-4 mb-4">
                    {{ form_label(form.telephone) }}
                    {{ form_widget(form.telephone) }}
                  </div>
              </div>
              <div data-mdb-input-init class="form-outline mb-4">
                  {{ form_label(form.autreResponsable) }}
                  {{ form_widget(form.autreResponsable) }}
              </div>
              <div class="row">
                  <div class="col-md-4 mb-4">
                    {{ form_label(form.fonction) }}
                    {{ form_widget(form.fonction) }}
                  </div>
                  <div class="col-md-4 mb-4">
                    {{ form_label(form.telephoneResponsable) }}
                    {{ form_widget(form.telephoneResponsable) }}
                  </div>
                  
              
              
            </div>
            <div class="col-xl-12 text-center">
                  <button  type="button" class="btn btn-light btn-lg">Reset all</button>
                  <button  type="submit"  class="btn btn-warning btn-lg text-center">Enregistrer</button>
              </div>
          </div>
          {{ form_end(form) }}
        </div>
      </div>
    </div>
  </div>
</section>
<footer class="text-center text-white mt-5">
  <div class="text-center p-3" style="background-color: rgba(0, 0, 0, 0.2);">
    © YOBS PRODUCTIONS {{ 'now'|date('Y') }} - Tous droits réservés
  </div>
</footer>
{% endblock %}
