                  </div>
                  <div class="col-md-4">
                    <div class="d-flex align-items-end">
                      <h2 class="d-flex align-items-end w-100 m-0">
                        <span class="fw-bold fs-5 me-2 text-nowrap text-dark">Tél :</span>
                        <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                      </h2>
                    </div>
                  </div>
              </div>

              {# Autre Responsable #}
