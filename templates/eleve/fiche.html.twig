{% extends 'base.html.twig' %}

{% block title %}Fiche de Renseignement Élève{% endblock %}

{% block body %}
<section class="h-100 bg-dark text-dark">
  <div class="container py-5 h-100">
    <div class="row d-flex justify-content-center align-items-center h-100">
      <div class="col">
        <div class="card card-registration my-4 bg-white shadow-lg">
