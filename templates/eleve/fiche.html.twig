{% extends 'base.html.twig' %}

{% block title %}Fiche de Renseignement Élève{% endblock %}

{% block body %}
<section class="h-100 bg-dark text-dark">
  <div class="container py-5 h-100">
    <div class="row d-flex justify-content-center align-items-center h-100">
      <div class="col">
        <div class="card card-registration my-4 bg-white shadow-lg">
          <div class="row g-0 p-5">
            
            <h3 class="mb-5 text-uppercase text-center w-100 fw-bold text-primary border-bottom pb-3">
              Fiche de Renseignement Élève
            </h3>
            
            {# --- SECTION 1 : INFORMATIONS ÉLÈVE (Gauche) --- #}
            <div class="col-xl-6 pe-xl-4 mb-4 mb-xl-0">
              <h5 class="mb-4 text-secondary border-bottom pb-2 fw-semibold">État Civil & Scolarité</h5>
              
              <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                  <div class="d-flex align-items-end">
                    <span class="fw-bold me-2 text-nowrap">Nom :</span>
                    <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="d-flex align-items-end">
                    <span class="fw-bold me-2 text-nowrap">Prénom :</span>
                    <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                  </div>
                </div>
              </div>

              <div class="row mb-4">
                <div class="col-md-4 mb-3 mb-md-0">
                  <div class="d-flex align-items-end">
                    <span class="fw-bold me-2 text-nowrap">Matricule :</span>
                    <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                  </div>
                </div>
                <div class="col-md-5 mb-3 mb-md-0">
                  <div class="d-flex align-items-end">
                    <span class="fw-bold me-2 text-nowrap">Né(e) le :</span>
                    <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="d-flex align-items-end">
                    <span class="fw-bold me-2 text-nowrap">Âge :</span>
                    <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                  </div>
                </div>
              </div>

              <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                  <div class="d-flex align-items-end">
                    <span class="fw-bold me-2 text-nowrap">Lieu de naissance :</span>
                    <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="d-flex align-items-end">
                    <span class="fw-bold me-2 text-nowrap">Ville :</span>
                    <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                  </div>
                </div>
              </div>

              <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                  <div class="d-flex align-items-end">
                    <span class="fw-bold me-2 text-nowrap">Classe :</span>
                    <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="d-flex align-items-center h-100">
                    <span class="fw-bold me-3 text-nowrap">Sexe :</span>
                    <div class="border border-dark me-2" style="width: 16px; height: 16px;"></div> <span class="me-3">M</span>
                    <div class="border border-dark me-2" style="width: 16px; height: 16px;"></div> <span>F</span>
                  </div>
                </div>
              </div>

              <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                  <div class="d-flex align-items-end">
                    <span class="fw-bold me-2 text-nowrap">Groupe Sanguin :</span>
                    <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="d-flex align-items-end">
                    <span class="fw-bold me-2 text-nowrap">Maladies / Allergies :</span>
                    <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                  </div>
                </div>
              </div>
            </div>

            {# --- SECTION 2 : RESPONSABLES LÉGAUX (Droite) --- #}
            <div class="col-xl-6 ps-xl-4">
              
              {# Informations Mère #}
              <h5 class="mb-4 text-secondary border-bottom pb-2 fw-semibold">Informations sur la Mère</h5>
              <div class="d-flex align-items-end mb-4">
                  <span class="fw-bold me-2 text-nowrap">Nom complet :</span>
                  <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
              </div>
              <div class="row mb-4">
                  <div class="col-md-5 mb-3 mb-md-0">
                    <div class="d-flex align-items-center h-100">
                      <span class="fw-bold me-2 lh-sm" style="font-size: 0.9rem;">Autorisée à récupérer l'enfant :</span>
                      <div class="border border-dark me-1" style="width: 14px; height: 14px; flex-shrink: 0;"></div> <span class="me-2">Oui_________________________</span>
                      <div class="border border-dark me-1" style="width: 14px; height: 14px; flex-shrink: 0;"></div> <span>Non_________________________</span>
                    </div>
                  </div>
                  <div class="col-md-3 mb-3 mb-md-0">
                    <div class="d-flex align-items-end">
                      <span class="fw-bold me-2 text-nowrap">Profession :</span>
                      <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="d-flex align-items-end">
                      <span class="fw-bold me-2 text-nowrap">Tél :</span>
                      <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                    </div>
                  </div>
              </div>

              {# Informations Père #}
              <h5 class="mb-4 text-secondary border-bottom pb-2 fw-semibold">Informations sur le Père</h5>
              <div class="d-flex align-items-end mb-4">
                  <span class="fw-bold me-2 text-nowrap">Nom complet :</span>
                  <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
              </div>
              <div class="row mb-4">
                  <div class="col-md-5 mb-3 mb-md-0">
                    <div class="d-flex align-items-center h-100">
                      <span class="fw-bold me-2 lh-sm" style="font-size: 0.9rem;">Autorisé à récupérer l'enfant :</span>
                      <div class="border border-dark me-1" style="width: 14px; height: 14px; flex-shrink: 0;"></div> <span class="me-2">Oui_________________________</span>
                      <div class="border border-dark me-1" style="width: 14px; height: 14px; flex-shrink: 0;"></div> <span>Non_________________________</span>
                    </div>
                  </div>
                  <div class="col-md-3 mb-3 mb-md-0">
                    <div class="d-flex align-items-end">
                      <span class="fw-bold me-2 text-nowrap">Profession :</span>
                      <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="d-flex align-items-end">
                      <span class="fw-bold me-2 text-nowrap">Tél :</span>
                      <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                    </div>
                  </div>
              </div>

              {# Autre Responsable #}
              <h5 class="mb-4 text-secondary border-bottom pb-2 fw-semibold">Autre Responsable Légal (si applicable)</h5>
              <div class="d-flex align-items-end mb-4">
                  <span class="fw-bold me-2 text-nowrap">Nom du tuteur :</span>
                  <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
              </div>
              <div class="row mb-4">
                  <div class="col-md-6 mb-3 mb-md-0">
                    <div class="d-flex align-items-end">
                      <span class="fw-bold me-2 text-nowrap">Lien de parenté :</span>
                      <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="d-flex align-items-end">
                      <span class="fw-bold me-2 text-nowrap">Tél. d'urgence :</span>
                      <span class="flex-grow-1 border-bottom border-dark border-1" style="height: 24px;">_________________________</span>
                    </div>
                  </div>
              </div>
            </div>

            {# Bloc Signature officiel #}
            <div class="col-12 mt-5 text-end pe-md-5">
              <p class="mb-5 fst-italic text-muted">Fait à _________________________, le ____/____/20___</p>
              <h6 class="fw-bold text-uppercase text-dark" style="letter-spacing: 1px;">Signature des parents / tuteur</h6>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% endblock %}