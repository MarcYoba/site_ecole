{% extends 'base.html.twig' %}

{% block title %}Inscriptions{% endblock %}

{% block body %}
    {% include "navbar.html.twig" %}

    <main class="flex-shrink-0 my-5">
        <div class="container">
            <div class="row">
                <div class="col-xl-12 mb-4"> {# Correction de la classe responsive Bootstrap #}
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped" id="dataTable" width="100%" cellspacing="0">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Nom</th>
                                        <th>Matricule</th>
                                        <th>Âge</th>
                                        <th>Téléphone</th>
                                        <th>Classe</th>
                                        <th>Sexe</th>
                                        <th>Date de naissance</th>
                                        <th>Opérations</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for eleve in eleves %}
                                        <tr>
                                            <td>{{ eleve.id }}</td>                                     
                                            <td>{{ eleve.nom }}</td> {# Corrigé : Accolades fermées #}
                                            <td>{{ eleve.matricule }}</td> {# Corrigé : Suppression du € et ajout de </td> #}
                                            <td>{{ eleve.age }}</td>
                                            <td>{{ eleve.telephone }}</td>
                                            <td>{{ eleve.classe.nom }}</td>
                                            <td>{{ eleve.sexe }}</td>
                                            <td>{{ eleve.naissance | date('Y-m-d') }}</td> 
                                            <td>
                                                <a href="#" class="btn btn-primary btn-sm" title="Modifier">
                                                    <i class="fas fa-pencil-alt"></i>
                                                </a>
                                                <a href="#" class="btn btn-danger btn-sm" title="Supprimer"
                                                   onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet élève ? Cette action est irréversible.');">
                                                    <i class="fas fa-trash-alt"></i>
                                                </a>
                                                <a href="#" class="btn btn-info btn-sm" title="Voir l'image">
                                                    <i class="far fa-file-image"></i>
                                                </a>
                                                <a href="{{ path('app_eleve_print', {'id': eleve.id}) }}" class="btn btn-success btn-sm" title="Imprimer">
                                                    <i class="fas fa-download"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    {% include "footer.html.twig" %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    {# Chargement des scripts externes #}
    {# <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/2.2.2/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.2.2/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function() {
            if ($('#dataTable').length) {
                $('#dataTable').DataTable({
                    pageLength: 25,
                    order: [[0, 'desc']], // Trie par la première colonne (ID) en descendant
                    //language: {
                       // url: 'https://cdn.datatables.net/plug-ins/2.2.2/i18n/fr-FR.json'
                    //}
                });
            } else {
            }
        });
    </script> #}
{% endblock %}