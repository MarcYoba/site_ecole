{% extends 'base.html.twig' %}

{% block title %}YOBSTIE{% endblock %}

{% block body %}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reçu - {{ soldes.id  }}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: #f0f0f0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .recu {
            max-width: 600px;
            width: 100%;
            background: white;
            border: 2px solid #333;
            padding: 30px;
            box-shadow: 10px 10px 0 rgba(0,0,0,0.1);
        }

        /* En-tête */
        .header {
            text-align: center;
            border-bottom: 2px dashed #999;
            padding-bottom: 20px;
            margin-bottom: 25px;
        }

        .header h1 {
            font-size: 24px;
            text-transform: uppercase;
            color: #2c3e50;
            letter-spacing: 2px;
        }

        .header h2 {
            font-size: 18px;
            color: #e67e22;
            margin-top: 5px;
        }

        .contact {
            font-size: 12px;
            color: #666;
            margin-top: 10px;
        }

        /* Infos reçu */
        .ref-bar {
            display: flex;
            justify-content: space-between;
            margin-bottom: 25px;
            font-size: 14px;
            font-weight: bold;
            border-bottom: 1px solid #ccc;
            padding-bottom: 10px;
        }

        .recu-numero {
            background: #f8f9fa;
            padding: 4px 8px;
        }

        /* Sections de contenu */
        .info-ligne {
            margin: 15px 0;
            padding: 8px 0;
            border-bottom: 1px dotted #ddd;
        }

        .label {
            font-weight: bold;
            display: inline-block;
            min-width: 120px;
            color: #555;
        }

        .value {
            display: inline-block;
            font-size: 16px;
        }

        .somme {
            font-size: 22px;
            font-weight: bold;
            color: #27ae60;
        }

        .ligne-double {
            display: flex;
            justify-content: space-between;
            margin: 12px 0;
        }

        .signature {
            margin-top: 40px;
            text-align: right;
            border-top: 1px solid #ddd;
            padding-top: 30px;
            font-style: italic;
        }

        @media print {
            body {
                background: white;
                padding: 0;
                margin: 0;
            }
            .recu {
                box-shadow: none;
                border: 1px solid #ccc;
                margin: 0;
                padding: 20px;
            }
            .no-print {
                display: none;
            }
        }

        .no-print {
            text-align: center;
            margin-top: 20px;
        }

        button {
            background: #3498db;
            color: white;
            border: none;
            padding: 10px 20px;
            cursor: pointer;
            border-radius: 4px;
        }

        button:hover {
            background: #2980b9;
        }
    </style>
</head>
<body>
    <div class="recu">
        {# En-tête de l'école #}
        <div class="header">
            <h1>{{ ecoles.nom | default('----') }}</h1>
            <h2>{{ecoles.sigle | default('----') }}</h2>
            <h3>{{ecoles.code | default('ARRETE N=057/J2/4829/A/MINEDUB/SG/DSEPB DU 04 AOUT 2010')}}</h3>
            <div class="contact">
               telephone {{ ecoles.telephone | default('----') }}
            </div>
        </div>

        {# Référence du reçu #}
        <div class="ref-bar">
            <span>RECU N° <strong>{{ soldes.id | default('----') }}</strong></span>
            <span> Date :  {{ soldes.createtAt | date('Y-m-d') }}</span>
            <span> Matricule :  {{ soldes.eleve.matricule | default('----') }}</span>
        </div>

        {# Corps du reçu #}
        <div class="content">
            <div class="info-ligne">
                <span class="label">Reçu de M/Mme :</span>
                <span class="value"><strong>{{ soldes.eleve.nom|upper }}</strong></span>
            </div>

            <div class="info-ligne">
                <span class="label">Accusé(e) de réception :</span>
                <span class="value">{{ soldes.eleve.pere|upper }} / {{soldes.eleve.mere |upper}}</span>
            </div>

            <div class="info-ligne">
                <span class="label">La somme total :</span>
                <span class="value somme">{{ pension.montant |number_format(0, ',', ' ') }} FCFA</span>
                {# <div class="value" style="font-size:12px; color:#666; margin-top:4px;">
                     recu.somme_lettres
                </div> #}
            </div>

            <div class="info-ligne">
                <span class="label">Pour :</span>
                <span class="value"><strong>Paiement de pension  {{ soldes.eleve.classe.nom | default('----') }}</strong></span>
                <br>
                <strong> Statistique Generale</strong>
            </div>

            {# Section paiement / avance / reste #}
            <div style="margin: 25px 0; background: #f9f9f9; padding: 15px;">
            
                {% for versement in versements %}
                    <div class="ligne-double">
                        <span class="label"><i class="fas fa-piggy-bank"></i>Avance: {{ versement.avance|default(0) }} FCFA</span>
                        <span class="label"><i class="fas fa-scale-balanced"></i> Reste: {{ versement.reste|default(0) }} FCFA</span>
                        <span class="value"><i class="fas fa-chart-bar"></i>  {{ (versement.tranche)|default(0) }}</span> 
                        <span class="value">{{versement.createtAt | date('Y-m-d')}}</span>
                    </div>
                {% endfor %}
            </div>

            <div class="info-ligne">
                <span class="label">Le mois de :</span>
                <span class="value">{{ soldes.createtAt | date('F Y') }}</span>
            </div>
        </div>
        
        <div class="signature row">
            <div class="col-md-6">
                <div style="text-align: left;">Signature de l'élève :</div>
                <div style="text-align: left;margin-top: 20px;">_________________________</div>
            </div>
            <div class="col-md-6">
                <div >Signature de l'élève :</div>
                <div style="margin-top: 20px;">_________________________</div>
            </div>
        </div>
    </div>
</body>
</html>
{% endblock %}