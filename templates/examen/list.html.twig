{% extends 'base.html.twig' %}

{% block title %}Inscriptions{% endblock %}

{% block body %}
    {% include "navbar.html.twig" %}

    <main class="flex-shrink-0 my-5">
        <div class="container">
            <div class="row">
                <div class="col-12 mb-4">
                    
                    <div class="card shadow">
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-bordered table-striped" id="tableactif" width="100%" cellspacing="0" data-page-length="25" data-order='[[0, "desc"]]'>
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Élève</th>
                                            <th>Classe</th>
                                            <th>Type paiement</th>
                                            <th>Montant</th>
                                            <th>Date</th>
                                            <th>Opération</th>
                                        </tr>
                                    </thead>
                                    <tfoot>
                                        <tr>
                                            <th>ID</th>
                                            <th>Élève</th>
                                            <th>Classe</th>
                                            <th>Type paiement</th>
                                            <th>Montant</th>
                                            <th>Date</th>
                                            <th>Opération</th>
                                        </tr>
                                    </tfoot>
                                    <tbody>
                                        {% for examen in examens %}
                                            <tr>
                                                <td>{{ examen.id }}</td>                                     
                                                <td>{{ examen.eleve.nom }}</td>
                                                <td>{{ examen.classe.nom }}</td>
                                                <td>{{ examen.typepaiement }}</td>
                                                <td>{{ examen.montant }}</td>
                                                <td>{{ examen.createtAt|date('Y-m-d') }}</td> 
                                                <td>
                                                    <a href="{{ path('app_examen_edit', {'id': examen.id}) }}" class="btn btn-primary" title="Modifier">
                                                        <i class="fas fa-pencil-alt"></i>
                                                    </a>
                                                    
                                                    <a href="{{ path('app_examen_facture', {'id': examen.id}) }}" class="btn btn-success" title="Télécharger la facture">
                                                        <i class="fas fa-download"></i>
                                                    </a>
                                                </td>
                                            </tr> 
                                        {% else %}
                                            <tr>
                                                <td colspan="7" class="text-center">Aucune inscription trouvée.</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div> </div> </div>
            </div>
        </div>
    </main>

    {% include "footer.html.twig" %}
{% endblock %}