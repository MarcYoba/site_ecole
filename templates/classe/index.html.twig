{% extends 'base.html.twig' %}

{% block title %}YOBS{% endblock %}

{% block body %}
{% include "navbar.html.twig" %}
<section class="vh-100">
  <div class="container ">
   
    <div class="row d-flex justify-content-center align-items-center h-100">
      <div class="col-xl-9">

        <h1 class="text-white mb-4">AJOUTER UNE CLASSE</h1>
        {{ form_start(form) }}
        <div class="card" style="border-radius: 15px;">
          <div class="card-body">
            <div class="form-group row">
              <div class="col-md-3">
                <a class="btn btn-primary" href="{{ path('app_classe_liste') }}"> Liste</a>
              </div>
            </div>
            <hr class="mx-n3">

            <div class="row align-items-center py-3">
              <div class="col-md-3 ps-5">

                <h6 class="mb-0">nom classe</h6>

              </div>
              <div class="col-md-9 pe-5">

                {{ form_widget(form.nom) }}

              </div>
            </div>

            <hr class="mx-n3">


            <div class="px-5 py-4">
              <button type="submit" data-mdb-button-init data-mdb-ripple-init class="btn btn-primary btn-lg">ENREGISTRER</button>
            </div>

          </div>
        </div>
        {{ form_end(form)  }}
      </div>
    </div>
  </div>
</section>
{% include "footer.html.twig" %}
{% endblock %}
