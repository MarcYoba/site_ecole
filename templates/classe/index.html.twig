{% extends 'base.html.twig' %}

{% block title %}Ajouter une classe - YOBS{% endblock %}

{% block body %}
    {% include "navbar.html.twig" %}

    <section class="vh-100">
        <div class="container">
            <div class="row d-flex justify-content-center align-items-center h-100">
                <div class="col-xl-9">
                    <h1 class="text-white mb-4">AJOUTER UNE CLASSE</h1>
                    
                    {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}
                    <div class="card" style="border-radius: 15px;">
                        <div class="card-body">
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <a class="btn btn-secondary" href="{{ path('app_classe_liste') }}">Retour à la liste</a>
                                </div>
                            </div>
                            <hr class="mx-n3">

                            {# On répète la structure pour chaque champ #}
                            {% for field in [form.nom, form.niveau, form.description, form.capacite, form.cession] %}
                                <div class="row align-items-center py-3">
                                    <div class="col-md-3 ps-5">
                                        {{ form_label(field, null, {'label_attr': {'class': 'mb-0'}}) }}
                                    </div>
                                    <div class="col-md-9 pe-5">
                                        {{ form_widget(field, {'attr': {'class': 'form-control'}}) }}
                                        <div class="text-danger">{{ form_errors(field) }}</div>
                                    </div>
                                </div>
                                <hr class="mx-n3">
                            {% endfor %}

                            <div class="px-5 py-4">
                                <button type="submit" class="btn btn-primary btn-lg">ENREGISTRER</button>
                            </div>
                        </div>
                    </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </section>

    {% include "footer.html.twig" %}
{% endblock %}