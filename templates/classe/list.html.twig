{% extends 'base.html.twig' %}

{% block title %}Dashboard | YOBS{% endblock %}

{% block body %}
{% include "navbar.html.twig" %}
<main class="flex-shrink-0 my-5">
    <div class="container">
        <div class="row">
            
            {% for classe in classes %} 
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="card border-0 border-start border-success border-4 shadow h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="flex-grow-1">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                    Classe
                                </div>
                                <div class="h5 mb-1 font-weight-bold text-gray-800">
                                    <i class="fas fa-chalkboard text-gray-300 me-2"></i>Nom : <span class="text-primary">{{ classe.nom }}</span>
                                </div>
                                <div class="small mb-0 font-weight-bold text-muted">
                                    <i class="fas fa-user-tie text-gray-300 me-2"></i>Enseignant : <span class="text-dark">M. Dupont</span>
                                </div>
                            </div>
                            <div class="ms-2">
                                <i class="fas fa-users fa-2x text-gray-200"></i>
                            </div>
                        </div>

                        <hr class="my-2 text-gray-200">

                        <div class="d-flex justify-content-between align-items-center pt-2">
                            <a href="#" class="btn btn-sm btn-outline-primary border-0">
                                <i class="fas fa-edit me-1"></i> Modifier
                            </a>
                            <a href="#" class="btn btn-sm btn-outline-danger border-0">
                                <i class="fas fa-trash me-1"></i> Supprimer
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

</main>
{% include "footer.html.twig" %}
{% endblock %}