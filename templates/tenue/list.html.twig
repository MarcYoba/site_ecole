{% extends 'base.html.twig' %}

{% block title %}Hello TenueController!{% endblock %}

{% block body %}
{% include "navbarsg.html.twig" %}
<main class="flex-shrink-0 my-5">
    <div class="container">
        <div class="row">
            <div class="col-xl-12 col-md-6 mb-4">
                <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-bordered" id="tableactif" width="100%" cellspacing="0" data-page-length='25' data-order='[[0, "desc"]]'>
                                    <thead>
                                       
                                        <tr>
                                            <th>id</th>
                                            <th>Nom</th>
                                            <th>classe</th>
                                            <th>montant</th>
                                            <th>Type paiement</th>
                                            <th>Type tenue</th>
                                            <th>Date</th>
                                            <th>Operation</th>
                                        </tr>
                                    </thead>
                                    <tfoot>
                                        <tr>
                                            <th>id</th>
                                            <th>Nom</th>
                                            <th>classe</th>
                                            <th>montant</th>
                                            <th>Type paiement</th>
                                            <th>Type tenue</th>
                                            <th>Date</th>
                                            <th>Operation</th>
                                        </tr>
                                    </tfoot>
                                    <tbody>
                                        {% for tenue in tenues %}
                                            <tr>
                                                <td>{{ tenue.id }}</td>                                     
                                                <td>{{ tenue.eleve.nom }}</td>
                                                <td>{{ tenue.eleve.classe.nom }}</td>
                                                <td>{{ tenue.montant }}</td>
                                                <td>{{ tenue.typepaiement }}</td>
                                                {% if tenue.typetenue == "TC" %}
                                                    <td>Tenue de classe</td>
                                                {% elseif tenue.typetenue == "TS" %}
                                                    <td>Tenue de sport</td>
                                                {% elseif tenue.typetenue == "TP" %}
                                                    <td>Pulle</td>
                                                {% elseif tenue.typetenue == "TCS" %}
                                                    <td>Tenue de classe et sport</td>
                                                {% elseif tenue.typetenue == "TCP" %}
                                                    <td>Tenue de classe et pulle</td>
                                                {% elseif tenue.typetenue == "TSP" %}
                                                    <td>Tenue de sport et pulle</td>
                                                {% elseif tenue.typetenue == "TCSP" %}
                                                    <td>Tenue de classe, sport et pulle</td>
                                                {% else %}
                                                    <td>0</td>
                                                {% endif %}
                                                <td>{{ tenue.createtAt | date('Y-m-d') }}</td> 
                                                
                                                    <td>
                                                        <a href='{{ path('app_tenue_edit', {'id':tenue.id}) }}' class='btn btn-primary' ><i class='fas fa-pencil-alt '></i></a>
                                                        <a href='#' class='btn btn-primary' id='modification'><i class='far fa-file-image'></i></a>
                                                        {# <a href='{{ path("app_tenue_facture", {"id": tenue.id}) }}' class='btn btn-primary' id='modification'><i class='fas fa-download'></i></a> #}
                                                    </td>
                                                
                                            </tr> 
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
            </div>
        </div>
    </div>

</main>
{% include "footer.html.twig" %}
{% endblock %}
